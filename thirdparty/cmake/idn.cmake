# libidn — pure CMake build (no autoconf)
# Replaces execute_process(./configure && make) with direct add_library.

set(IDN_SRC ${TP_SOURCE_DIR}/libidn-1.38)
set(IDN_CONFIG_DIR ${CMAKE_CURRENT_BINARY_DIR}/idn_config)
file(MAKE_DIRECTORY ${IDN_CONFIG_DIR})

# Generate idn-int.h (typically just stdint.h on modern Linux)
file(WRITE ${IDN_CONFIG_DIR}/idn-int.h
"/* Generated by CMake — idn-int.h for Linux */
#include <stdint.h>
")
# Run configure and make -C lib/gl to generate gnulib headers during build phase
set(IDN_CONFIG_H "${IDN_SRC}/config.h")
add_custom_command(
    OUTPUT ${IDN_CONFIG_H}
    COMMAND env CFLAGS=-fPIC CXXFLAGS=-fPIC ./configure --with-pic --disable-shared --disable-doc --disable-csharp --disable-ja
    COMMAND make -C lib/gl
    COMMAND bash -c "echo '/* Appended by CMake wrapper to emulate missing gnulib defines */
#define _GL_INLINE static inline
#define _GL_EXTERN_INLINE static inline
#define _GL_INLINE_HEADER_BEGIN
#define _GL_INLINE_HEADER_END
#define _GL_ATTRIBUTE_PURE
#define _GL_ARG_NONNULL(args)
#define _GL_CMP(n1, n2) (((n1) > (n2)) - ((n1) < (n2)))' >> config.h"
    WORKING_DIRECTORY ${IDN_SRC}
    COMMENT "Configuring libidn and building gl helpers..."
)
add_custom_target(idn_config_headers DEPENDS ${IDN_CONFIG_H})

# Source files — the 17 library .c files (excluding gl/ gnulib helpers)
add_library(_idn STATIC
    ${IDN_SRC}/lib/idn-free.c
    ${IDN_SRC}/lib/idna.c
    ${IDN_SRC}/lib/nfkc.c
    ${IDN_SRC}/lib/pr29.c
    ${IDN_SRC}/lib/profiles.c
    ${IDN_SRC}/lib/punycode.c
    ${IDN_SRC}/lib/rfc3454.c
    ${IDN_SRC}/lib/strerror-idna.c
    ${IDN_SRC}/lib/strerror-pr29.c
    ${IDN_SRC}/lib/strerror-punycode.c
    ${IDN_SRC}/lib/strerror-stringprep.c
    ${IDN_SRC}/lib/strerror-tld.c
    ${IDN_SRC}/lib/stringprep.c
    ${IDN_SRC}/lib/tld.c
    ${IDN_SRC}/lib/tlds.c
    ${IDN_SRC}/lib/toutf8.c
    ${IDN_SRC}/lib/version.c
    # gnulib helpers used by stringprep.c (for iconv wrappers)
    ${IDN_SRC}/lib/gl/c-ctype.c
    ${IDN_SRC}/lib/gl/c-strcasecmp.c
    ${IDN_SRC}/lib/gl/c-strncasecmp.c
    ${IDN_SRC}/lib/gl/strverscmp.c
)

target_include_directories(_idn
    PRIVATE ${IDN_CONFIG_DIR}        # idn-int.h
    PRIVATE ${IDN_SRC}
    PRIVATE ${IDN_SRC}/lib           # internal headers
    PRIVATE ${IDN_SRC}/lib/gl        # gnulib headers
    PUBLIC  ${IDN_SRC}/lib           # public API (stringprep.h, idna.h, etc.)
)

target_compile_definitions(_idn PRIVATE
    HAVE_CONFIG_H
    LIBIDN_BUILDING
    _GNU_SOURCE
    "LOCALEDIR=\"/usr/local/share/locale\""
    HAVE_GETPWUID_R=1
    HAVE_LONG_LONG_INT=1
    SIZEOF_LONG=8
)

target_compile_options(_idn PRIVATE -fPIC -w)

add_library(idn ALIAS _idn)
add_dependencies(_idn idn_config_headers)
